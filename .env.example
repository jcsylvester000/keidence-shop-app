# Neon.tech Postgres connection string (Prisma / Neon serverless driver).
# Get this from the Neon dashboard → Connection Details → Prisma.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# Secret used to sign the session cookie. Use a long random string in prod.
SESSION_SECRET="change-me-to-a-long-random-string"
